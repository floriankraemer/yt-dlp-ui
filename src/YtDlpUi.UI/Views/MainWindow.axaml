<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:YtDlpUi.UI.ViewModels"
        xmlns:models="clr-namespace:YtDlpUi.Core.Models;assembly=YtDlpUi.Core"
        x:Class="YtDlpUi.UI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Yt-dlp-ui"
        Width="1000"
        Height="700"
        MinWidth="800"
        MinHeight="520">
  <DockPanel LastChildFill="True">
    <Border DockPanel.Dock="Top" Padding="12" BorderThickness="0,0,0,1"
            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
      <StackPanel Spacing="8">
        <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="8">
          <TextBox Grid.Column="0"
                   Watermark="Paste YouTube or video URL"
                   Text="{Binding UrlInput}"
                   KeyDown="UrlInput_KeyDown" />
          <ComboBox Grid.Column="1"
                    MinWidth="200"
                    MaxWidth="280"
                    ItemsSource="{Binding Profiles}"
                    SelectedItem="{Binding SelectedProfile}"
                    PlaceholderText="Profile"
                    VerticalAlignment="Center">
            <ComboBox.ItemTemplate>
              <DataTemplate x:DataType="models:DownloadProfile">
                <TextBlock Text="{Binding Name}" />
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
          <Button Grid.Column="2" Content="Add" Click="Add_Click" />
          <Button Grid.Column="3" Content="Search" Click="Search_Click" />
          <Button Grid.Column="4" Content="Settings" Click="Settings_Click" />
          <Button Grid.Column="5" Content="Install yt-dlp" Click="InstallYtDlp_Click" />
          <Button Grid.Column="6" Content="Install ffmpeg" Click="InstallFfmpeg_Click" />
          <ProgressBar Grid.Column="7" Width="120" IsIndeterminate="True" IsVisible="{Binding IsBusy}" />
        </Grid>
        <TextBlock Text="{Binding YtDlpStatus}" FontSize="12" Opacity="0.8" />
        <TextBlock Text="{Binding FfmpegStatus}" FontSize="12" Opacity="0.8" />
        <TextBlock Text="{Binding StatusMessage}" />
        <TextBlock Text="{Binding ErrorMessage}"
                   Foreground="{DynamicResource SystemControlErrorTextForegroundBrush}" />
      </StackPanel>
    </Border>

    <Grid Margin="12" MinHeight="200">
      <DataGrid x:Name="JobsDataGrid"
                ItemsSource="{Binding Jobs}"
                AutoGenerateColumns="False"
                CanUserReorderColumns="True"
                CanUserResizeColumns="True"
                IsReadOnly="True"
                GridLinesVisibility="Horizontal"
                BorderThickness="1"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                IsVisible="{Binding HasJobs}"
                PointerReleased="JobsDataGrid_PointerReleased">
      <DataGrid.ContextMenu>
        <ContextMenu x:Name="JobContextMenu" Opening="JobContextMenu_Opening">
          <MenuItem x:Name="OpenOutputMenuItem" Click="OpenOutput_Click" />
          <Separator x:Name="OpenOutputSeparator" />
          <MenuItem x:Name="StartJobMenuItem" Header="Start" Click="StartJob_Click" />
          <MenuItem x:Name="ViewLogMenuItem" Header="Log" Click="ViewLog_Click" />
          <MenuItem x:Name="CancelJobMenuItem" Header="Cancel" Click="CancelJob_Click" />
          <MenuItem x:Name="RemoveJobMenuItem" Header="Remove" Click="RemoveJob_Click" />
        </ContextMenu>
      </DataGrid.ContextMenu>
      <DataGrid.Columns>
        <DataGridTextColumn Header="Status" Binding="{Binding StatusText}" Width="90" />
        <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="*" />
        <DataGridTextColumn Header="URL" Binding="{Binding Url}" Width="2*" />
        <DataGridTemplateColumn Header="Progress" Width="140">
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate x:DataType="vm:DownloadJobViewModel">
              <Grid Height="18" VerticalAlignment="Center">
                <ProgressBar Minimum="0"
                             Maximum="100"
                             Value="{Binding Progress}"
                             IsIndeterminate="{Binding IsProgressIndeterminate}"
                             ShowProgressText="{Binding !IsProgressIndeterminate}" />
                <TextBlock Text="{Binding ProgressDisplayText}"
                           IsVisible="{Binding IsProgressIndeterminate}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="11" />
              </Grid>
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>
        <DataGridTextColumn Header="Speed" Binding="{Binding Speed}" Width="80" />
        <DataGridTextColumn Header="ETA" Binding="{Binding Eta}" Width="80" />
        <DataGridTextColumn Header="Error" Binding="{Binding Error}" Width="2*" />
        <DataGridTemplateColumn Header="Actions" Width="260">
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate x:DataType="vm:DownloadJobViewModel">
              <StackPanel Orientation="Horizontal" Spacing="4">
                <Button Content="Start" IsVisible="{Binding CanStart}" Click="StartJob_Click" />
                <Button Content="Log" IsVisible="{Binding CanViewLog}" Click="ViewLog_Click" />
                <Button Content="Cancel" IsVisible="{Binding CanCancel}" Click="CancelJob_Click" />
                <Button Content="Remove" IsVisible="{Binding CanRemove}" Click="RemoveJob_Click" />
              </StackPanel>
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>
      </DataGrid.Columns>
      </DataGrid>
      <Border IsVisible="{Binding !HasJobs}"
              BorderThickness="1"
              BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
              Padding="24"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch">
        <TextBlock Text="No downloads in the queue. Paste a URL above and click Add."
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   TextAlignment="Center"
                   Opacity="0.7"
                   TextWrapping="Wrap" />
      </Border>
    </Grid>
  </DockPanel>
</Window>

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="YtDlpUi.UI.Views.DownloadFolderSetupWindow"
        Title="Choose download folder"
        Width="560"
        Height="220"
        MinWidth="480"
        WindowStartupLocation="CenterOwner"
        CanResize="False">
  <DockPanel Margin="16">
    <StackPanel DockPanel.Dock="Bottom"
                Orientation="Horizontal"
                Spacing="8"
                HorizontalAlignment="Right"
                Margin="0,16,0,0">
      <Button Content="Continue" Click="Continue_Click" IsDefault="True" />
    </StackPanel>

    <StackPanel Spacing="12">
      <TextBlock Text="Welcome to Yt-dlp-ui"
                 FontWeight="SemiBold"
                 FontSize="16" />
      <TextBlock Text="Choose where downloaded videos should be saved. You can change this later in Settings → Queue."
                 TextWrapping="Wrap"
                 Opacity="0.85" />
      <TextBlock x:Name="ErrorText"
                Foreground="{DynamicResource SystemControlErrorTextForegroundBrush}"
                TextWrapping="Wrap" />
      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
        <TextBox x:Name="FolderPathBox"
                 Watermark="Download folder"
                 AcceptsReturn="False" />
        <Button Grid.Column="1" Content="Browse…" Click="Browse_Click" />
      </Grid>
    </StackPanel>
  </DockPanel>
</Window>

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:YtDlpUi.UI.ViewModels"
        xmlns:models="clr-namespace:YtDlpUi.Core.Models;assembly=YtDlpUi.Core"
        x:Class="YtDlpUi.UI.Views.SearchWindow"
        x:DataType="vm:SearchViewModel"
        Title="Search YouTube"
        Width="900"
        Height="640"
        MinWidth="720"
        MinHeight="480"
        WindowStartupLocation="CenterOwner">
  <DockPanel Margin="12">
    <StackPanel DockPanel.Dock="Bottom" Spacing="8" Margin="0,12,0,0">
      <TextBlock Text="{Binding StatusMessage}" Opacity="0.9" />
      <TextBlock Text="{Binding ErrorMessage}"
                 Foreground="{DynamicResource SystemControlErrorTextForegroundBrush}" />
      <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
        <Button Content="Close" Click="Close_Click" />
      </StackPanel>
    </StackPanel>

    <StackPanel DockPanel.Dock="Top" Spacing="8" Margin="0,0,0,12">
      <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
        <TextBox Grid.Column="0"
                 Watermark="Search YouTube"
                 Text="{Binding SearchQuery}"
                 KeyDown="SearchQuery_KeyDown" />
        <Button Grid.Column="1" Content="Search" Click="Search_Click" />
        <ProgressBar Grid.Column="2"
                     Width="100"
                     IsIndeterminate="True"
                     IsVisible="{Binding IsSearching}" />
      </Grid>
    </StackPanel>

    <ScrollViewer>
      <ItemsControl ItemsSource="{Binding Results}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:SearchResultViewModel">
            <Border Padding="8"
                    Margin="0,0,0,8"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                    CornerRadius="4">
              <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="12">
                <Border Grid.Column="0"
                        Width="120"
                        Height="68"
                        Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                        CornerRadius="2"
                        ClipToBounds="True">
                  <Grid>
                    <Image Source="{Binding Thumbnail}"
                           Stretch="UniformToFill" />
                    <TextBlock Text="…"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Opacity="0.5"
                               IsVisible="{Binding IsLoadingThumbnail}" />
                  </Grid>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                  <TextBlock Text="{Binding Title}"
                             FontWeight="SemiBold"
                             TextWrapping="Wrap"
                             MaxLines="2" />
                  <TextBlock Text="{Binding Channel}"
                             Opacity="0.8"
                             TextWrapping="Wrap" />
                  <TextBlock Text="{Binding StatusMessage}"
                             FontSize="12"
                             Opacity="0.9" />
                </StackPanel>

                <ComboBox Grid.Column="2"
                          MinWidth="180"
                          MaxWidth="220"
                          ItemsSource="{Binding Profiles}"
                          SelectedItem="{Binding SelectedProfile}"
                          PlaceholderText="Profile"
                          VerticalAlignment="Center">
                  <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="models:DownloadProfile">
                      <TextBlock Text="{Binding Name}" />
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>

                <Button Grid.Column="3"
                        Content="Add to queue"
                        VerticalAlignment="Center"
                        IsEnabled="{Binding CanAdd}"
                        Click="AddToQueue_Click" />
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>
  </DockPanel>
</Window>
